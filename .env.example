# Environment Variables for Railway Deployment
# Copy this file to .env and fill in your values, OR set these directly in Railway dashboard

# Required
MISTRAL_API_KEY=your_mistral_api_key_here
DATABASE_URL=your_neon_postgres_connection_string_here

# Optional - Redis for rate limiting (falls back to in-memory if not set)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Optional
MISTRAL_BASE_URL=https://api.mistral.ai
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=Lenormand Intelligence
