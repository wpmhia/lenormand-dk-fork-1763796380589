{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",
  "installCommand": "npm ci",
  "crons": [
    {
      "path": "/api/health",
      "schedule": "0 0 * * *"
    }
  ],
  "env": {
    "MISTRAL_API_KEY": {
      "description": "Mistral API key for AI interpretation"
    },
    "MISTRAL_BASE_URL": {
      "description": "Mistral API base URL (optional, defaults to https://api.mistral.ai)",
      "default": "https://api.mistral.ai"
    },
    "UPSTASH_REDIS_REST_URL": {
      "description": "Upstash Redis for persistent caching"
    },
    "UPSTASH_REDIS_REST_TOKEN": {
      "description": "Upstash Redis authentication token"
    }
  },
  "functions": {
    "app/api/readings/interpret/route.ts": {
      "maxDuration": 10
    },
    "app/api/health/route.ts": {
      "maxDuration": 10
    }
  },
  "regions": ["fra1", "ams1", "dub1", "lhr1"],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
